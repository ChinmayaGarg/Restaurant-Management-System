generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////
// ENUMS
////////////////////////

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  OUT_OF_SERVICE
}

enum TableSessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum OrderSourceType {
  QR
  STAFF
  KIOSK
  MOBILE_APP
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY
  SERVED
  CANCELLED
  CLOSED
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum ServiceRequestType {
  CALL_SERVER
  REQUEST_BILL
  WATER
  CLEANING
  HELP
  READY_TO_ORDER
}

enum ServiceRequestSourceType {
  QR
  BUTTON
  STAFF
  SYSTEM
}

enum ServiceRequestStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  ESCALATED
  CANCELLED
}

enum BillStatus {
  DRAFT
  GENERATED
  PAID
  VOID
  CLOSED
}

enum PaymentMethod {
  CASH
  CARD
  ONLINE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum AuditEntityType {
  USER
  ROLE
  TABLE
  TABLE_SESSION
  MENU_ITEM
  ORDER
  SERVICE_REQUEST
  BILL
  PAYMENT
  SETTINGS
}

enum CourseType {
  APPETIZER
  ENTREE
  DESSERT
  DRINK
  SIDE
  OTHER
}

enum FireStatus {
  HOLD
  FIRED
  IN_PREP
  READY
  SERVED
  VOIDED
}

////////////////////////
// RESTAURANT STRUCTURE
////////////////////////

model Restaurant {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  timezone   String
  currency   String
  status     RecordStatus @default(ACTIVE)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  branches   Branch[]
  roles      Role[]
}

model Branch {
  id           String    @id @default(cuid())
  restaurantId String
  name         String
  address      String?
  phone        String?
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  sections     Section[]
  users        User[]
  tables       DiningTable[]
  menuCategories MenuCategory[]
  moduleConfig ModuleConfig?
  taxConfigs   TaxConfig[]
  notifications Notification[]

  @@index([restaurantId])
}

model Section {
  id           String    @id @default(cuid())
  branchId      String
  name          String
  displayOrder  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch        Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tables        DiningTable[]
  userScopes    AccessScope[]

  @@unique([branchId, name])
  @@index([branchId])
}

////////////////////////
// USERS / ROLES / PERMISSIONS
////////////////////////

model User {
  id            String      @id @default(cuid())
  branchId       String
  firstName      String
  lastName       String
  email          String      @unique
  phone          String?
  status         RecordStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  branch         Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  credential     Credential?
  userRoles      UserRole[]
  scopes         AccessScope[]

  openedSessions TableSession[] @relation("OpenedByUser")
  assignedServerSessions TableSession[] @relation("AssignedServerSessions")
  assignedByUserSessions TableSession[] @relation("AssignedByUserSessions")
  createdOrders  Order[]        @relation("CreatedByUser")
  orderStatusHistory OrderStatusHistory[]
  createdServiceRequests ServiceRequest[] @relation("CreatedServiceRequestByUser")
  tableAssignmentsFrom TableSessionAssignmentHistory[] @relation("TableAssignmentFromUser")
  tableAssignmentsTo TableSessionAssignmentHistory[] @relation("TableAssignmentToUser")
  tableAssignmentsChanged TableSessionAssignmentHistory[] @relation("TableAssignmentChangedByUser")
  orderItemsAdded OrderItem[] @relation("OrderItemsAddedByUser")
  assignedServiceRequests ServiceRequest[] @relation("AssignedServiceRequestToUser")
  serviceRequestHistory ServiceRequestHistory[]
  generatedBills Bill[]         @relation("GeneratedByUser")
  billAdjustments BillAdjustment[]
  recordedPayments Payment[]    @relation("RecordedByUser")
  auditLogs      AuditLog[]
  targetedNotifications Notification[]

  @@index([branchId])
}

model Credential {
  id            String    @id @default(cuid())
  userId         String    @unique
  passwordHash   String
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id            String      @id @default(cuid())
  restaurantId   String
  name           String
  description    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles      UserRole[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model Permission {
  id            String      @id @default(cuid())
  key           String      @unique
  module        String
  description   String?
  createdAt     DateTime    @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String
  permissionId  String

  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRole {
  id            String    @id @default(cuid())
  userId         String
  roleId         String
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model AccessScope {
  id            String    @id @default(cuid())
  userId         String
  scopeType      String
  scopeValue     String?
  sectionId      String?
  createdAt      DateTime  @default(now())

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  section        Section?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sectionId])
}

////////////////////////
// TABLES / SESSIONS
////////////////////////

model DiningTable {
  id            String      @id @default(cuid())
  branchId       String
  sectionId      String
  tableCode      String
  displayName    String
  capacity       Int
  status         TableStatus @default(AVAILABLE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  branch         Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  section        Section     @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  sessions       TableSession[]

  @@unique([branchId, tableCode])
  @@index([branchId])
  @@index([sectionId])
}

model TableSession {
  id              String             @id @default(cuid())
  tableId          String
  openedByUserId   String
  assignedServerId String?
  assignedByUserId String?
  assignedAt       DateTime?
  status           TableSessionStatus @default(OPEN)
  guestCount       Int?
  openedAt         DateTime           @default(now())
  closedAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  table            DiningTable        @relation(fields: [tableId], references: [id], onDelete: Restrict)
  openedByUser     User               @relation("OpenedByUser", fields: [openedByUserId], references: [id], onDelete: Restrict)
  assignedServer   User?              @relation("AssignedServerSessions", fields: [assignedServerId], references: [id], onDelete: SetNull)
  assignedByUser   User?              @relation("AssignedByUserSessions", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  orders           Order[]
  serviceRequests  ServiceRequest[]
  bills            Bill[]
  seatAssignments  SeatAssignment[]
  assignmentHistory TableSessionAssignmentHistory[]

  @@index([tableId])
  @@index([openedByUserId])
  @@index([assignedServerId])
  @@index([status])
}

model SeatAssignment {
  id             String       @id @default(cuid())
  tableSessionId String
  seatNumber     Int?
  label          String
  isShared       Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tableSession   TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]

  @@index([tableSessionId])
  @@unique([tableSessionId, seatNumber])
}

model TableSessionAssignmentHistory {
  id               String       @id @default(cuid())
  tableSessionId   String
  fromUserId       String?
  toUserId         String?
  changedByUserId  String
  reason           String?
  startedAt        DateTime     @default(now())
  endedAt          DateTime?

  tableSession     TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  fromUser         User?        @relation("TableAssignmentFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser           User?        @relation("TableAssignmentToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  changedByUser    User         @relation("TableAssignmentChangedByUser", fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([tableSessionId])
  @@index([toUserId])
}

////////////////////////
// MENU
////////////////////////

model MenuCategory {
  id            String      @id @default(cuid())
  branchId       String
  name           String
  description    String?
  displayOrder   Int         @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  branch         Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items          MenuItem[]

  @@unique([branchId, name])
  @@index([branchId])
}

model MenuItem {
  id             String      @id @default(cuid())
  categoryId      String
  name            String
  description     String?
  basePrice       Decimal     @db.Decimal(10, 2)
  isAvailable     Boolean     @default(true)
  sku             String?
  imageUrl        String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  category        MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  modifierGroups  ModifierGroup[]
  orderItems      OrderItem[]

  @@index([categoryId])
  @@unique([categoryId, name])
}

model ModifierGroup {
  id             String      @id @default(cuid())
  menuItemId      String
  name            String
  minSelect       Int         @default(0)
  maxSelect       Int         @default(1)
  isRequired      Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  menuItem        MenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options         ModifierOption[]

  @@index([menuItemId])
}

model ModifierOption {
  id             String      @id @default(cuid())
  modifierGroupId String
  name           String
  priceDelta     Decimal     @db.Decimal(10, 2)
  isAvailable    Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  modifierGroup  ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
}

////////////////////////
// ORDERS
////////////////////////

model Order {
  id              String          @id @default(cuid())
  tableSessionId   String
  sourceType       OrderSourceType
  createdByUserId  String?
  notes            String?
  status           OrderStatus     @default(PLACED)
  subtotalAmount   Decimal         @default(0) @db.Decimal(10, 2)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tableSession     TableSession    @relation(fields: [tableSessionId], references: [id], onDelete: Restrict)
  createdByUser    User?           @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items            OrderItem[]
  statusHistory    OrderStatusHistory[]

  @@index([tableSessionId])
  @@index([createdByUserId])
  @@index([status])
}

model OrderItem {
  id                 String          @id @default(cuid())
  orderId            String
  menuItemId         String
  seatAssignmentId   String?
  quantity           Int
  unitPrice          Decimal         @db.Decimal(10, 2)
  lineTotal          Decimal         @db.Decimal(10, 2)
  specialInstructions String?
  status             OrderItemStatus @default(PENDING)
  courseType         CourseType      @default(ENTREE)
  courseRound        Int             @default(1)
  fireStatus         FireStatus      @default(FIRED)
  addedByUserId      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  order              Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem           MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  seatAssignment     SeatAssignment? @relation(fields: [seatAssignmentId], references: [id], onDelete: SetNull)
  addedByUser        User?           @relation("OrderItemsAddedByUser", fields: [addedByUserId], references: [id], onDelete: SetNull)
  modifiers          OrderItemModifier[]
  billItems          BillItem[]

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
  @@index([seatAssignmentId])
  @@index([addedByUserId])
  @@index([courseType])
  @@index([fireStatus])
}

model OrderItemModifier {
  id               String         @id @default(cuid())
  orderItemId      String
  modifierOptionId String
  priceDelta       Decimal        @db.Decimal(10, 2)

  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
  @@index([modifierOptionId])
}

model OrderStatusHistory {
  id              String      @id @default(cuid())
  orderId          String
  fromStatus       OrderStatus?
  toStatus         OrderStatus
  changedByUserId  String?
  changedAt        DateTime    @default(now())

  order            Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser    User?       @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([changedByUserId])
}

////////////////////////
// SERVICE REQUESTS
////////////////////////

model ServiceRequest {
  id               String                   @id @default(cuid())
  tableSessionId    String
  requestType       ServiceRequestType
  sourceType        ServiceRequestSourceType
  sourceDeviceId    String?
  status            ServiceRequestStatus     @default(OPEN)
  createdByUserId   String?
  assignedToUserId  String?
  createdAt         DateTime                 @default(now())
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?

  tableSession      TableSession             @relation(fields: [tableSessionId], references: [id], onDelete: Restrict)
  createdByUser     User?                    @relation("CreatedServiceRequestByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedToUser    User?                    @relation("AssignedServiceRequestToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  history           ServiceRequestHistory[]

  @@index([tableSessionId])
  @@index([createdByUserId])
  @@index([assignedToUserId])
  @@index([status])
}

model ServiceRequestHistory {
  id                String               @id @default(cuid())
  serviceRequestId   String
  fromStatus         ServiceRequestStatus?
  toStatus           ServiceRequestStatus
  changedByUserId    String?
  changedAt          DateTime             @default(now())

  serviceRequest     ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  changedByUser      User?                @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([serviceRequestId])
  @@index([changedByUserId])
}

////////////////////////
// BILLING
////////////////////////

model Bill {
  id                  String      @id @default(cuid())
  tableSessionId       String
  billNumber           String      @unique
  status               BillStatus  @default(DRAFT)
  subtotalAmount       Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount       Decimal     @default(0) @db.Decimal(10, 2)
  taxAmount            Decimal     @default(0) @db.Decimal(10, 2)
  serviceChargeAmount  Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount          Decimal     @default(0) @db.Decimal(10, 2)
  generatedByUserId    String?
  generatedAt          DateTime?
  closedAt             DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  tableSession         TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Restrict)
  generatedByUser      User?        @relation("GeneratedByUser", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  items                BillItem[]
  adjustments          BillAdjustment[]
  payments             Payment[]

  @@index([tableSessionId])
  @@index([generatedByUserId])
  @@index([status])
}

model BillItem {
  id             String    @id @default(cuid())
  billId          String
  orderItemId     String?
  nameSnapshot    String
  quantity        Int
  unitPrice       Decimal   @db.Decimal(10, 2)
  lineTotal       Decimal   @db.Decimal(10, 2)

  bill            Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  orderItem       OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([orderItemId])
}

model BillAdjustment {
  id              String    @id @default(cuid())
  billId           String
  type             String
  label            String
  amount           Decimal   @db.Decimal(10, 2)
  reason           String?
  createdByUserId  String?
  createdAt        DateTime  @default(now())

  bill             Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  createdByUser    User?     @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([createdByUserId])
}

////////////////////////
// PAYMENTS
////////////////////////

model Payment {
  id                String        @id @default(cuid())
  billId             String
  method             PaymentMethod
  provider           String?
  providerReference  String?
  amount             Decimal       @db.Decimal(10, 2)
  status             PaymentStatus @default(PENDING)
  recordedByUserId   String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  bill               Bill          @relation(fields: [billId], references: [id], onDelete: Restrict)
  recordedByUser     User?         @relation("RecordedByUser", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@index([billId])
  @@index([recordedByUserId])
  @@index([status])
}

////////////////////////
// SETTINGS
////////////////////////

model ModuleConfig {
  id                 String    @id @default(cuid())
  branchId           String    @unique
  qrEnabled          Boolean   @default(false)
  buttonEnabled      Boolean   @default(false)
  selfOrderEnabled   Boolean   @default(false)
  selfPaymentEnabled Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  branch             Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model TaxConfig {
  id          String    @id @default(cuid())
  branchId    String
  name        String
  rate        Decimal   @db.Decimal(5, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, name])
  @@index([branchId])
}

////////////////////////
// AUDIT
////////////////////////

model AuditLog {
  id           String          @id @default(cuid())
  actorUserId  String?
  action       String
  entityType   AuditEntityType
  entityId     String
  oldValue     Json?
  newValue     Json?
  createdAt    DateTime        @default(now())

  actorUser    User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id               String    @id @default(cuid())
  branchId         String
  title            String
  message          String
  type             String
  isRead           Boolean   @default(false)
  targetUserId     String?
  createdAt        DateTime  @default(now())
  readAt           DateTime?

  branch           Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  targetUser       User?     @relation(fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([targetUserId])
  @@index([isRead])
  @@index([createdAt])
}
