{
  "name": "backend",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json --listEmittedFiles",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "start": "node ./dist/main.js",
    "start:watch": "nodemon --watch dist/main.js --exec \"node ./dist/main.js\"",
    "start:dev": "pnpm build && concurrently -k -n TSC,NODE -c yellow,cyan \"pnpm build:watch\" \"pnpm start:watch\"",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/client": "5.22.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "prisma": "5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seeds/index.ts"
  }
}
